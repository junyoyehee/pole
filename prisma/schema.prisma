generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String   @id @default(uuid())
  email         String   @unique
  passwordHash  String   @map("password_hash")
  name          String
  avatarUrl     String?  @map("avatar_url")
  role          String   @default("MEMBER") // MEMBER, LEAD, ADMIN
  part          String   // FRONTEND, BACKEND, DESIGN, PM, QA
  position      String?
  status        String   @default("OFFLINE") // WORKING, IN_MEETING, AWAY, VACATION, OFFLINE
  slackHandle   String?  @map("slack_handle")
  bio           String?
  createdAt     DateTime @default(now()) @map("created_at")

  // Relations
  figmaProjects     FigmaProject[]   @relation("FigmaDesigner")
  designReviews     DesignReview[]   @relation("ReviewAuthor")
  reviewFeedbacks   ReviewFeedback[]
  handoffs          Handoff[]        @relation("HandoffDeveloper")
  comments          Comment[]

  @@map("users")
}

model FigmaProject {
  id           String   @id @default(uuid())
  name         String
  figmaUrl     String?  @map("figma_url")
  fileKey      String?  @map("file_key")
  description  String?
  status       String   @default("DESIGNING") // DESIGNING, IN_REVIEW, IN_DEV, DONE
  designerId   String   @map("designer_id")
  thumbnailUrl String?  @map("thumbnail_url")
  createdAt    DateTime @default(now()) @map("created_at")

  designer User           @relation("FigmaDesigner", fields: [designerId], references: [id])
  reviews  DesignReview[]
  handoffs Handoff[]

  @@map("figma_projects")
}

model DesignReview {
  id             String   @id @default(uuid())
  figmaProjectId String   @map("figma_project_id")
  title          String
  description    String?
  figmaNodeId    String?  @map("figma_node_id")
  figmaUrl       String?  @map("figma_url")
  status         String   @default("OPEN") // OPEN, IN_REVISION, APPROVED
  authorId       String   @map("author_id")
  dueDate        String?  @map("due_date")
  previewImages  String?  @map("preview_images") // JSON array
  createdAt      DateTime @default(now()) @map("created_at")

  figmaProject FigmaProject     @relation(fields: [figmaProjectId], references: [id], onDelete: Cascade)
  author       User             @relation("ReviewAuthor", fields: [authorId], references: [id])
  feedbacks    ReviewFeedback[]

  @@map("design_reviews")
}

model ReviewFeedback {
  id        String   @id @default(uuid())
  reviewId  String   @map("review_id")
  authorId  String   @map("author_id")
  content   String
  category  String   @default("OTHER") // UI, UX, A11Y, TECHNICAL, OTHER
  priority  String   @default("NORMAL") // HIGH, NORMAL, LOW
  type      String   @default("COMMENT") // COMMENT, CHANGE_REQUEST, APPROVAL
  createdAt DateTime @default(now()) @map("created_at")

  review DesignReview @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  author User         @relation(fields: [authorId], references: [id])

  @@map("review_feedbacks")
}

model Handoff {
  id             String   @id @default(uuid())
  figmaProjectId String   @map("figma_project_id")
  componentName  String   @map("component_name")
  figmaNodeId    String?  @map("figma_node_id")
  figmaUrl       String?  @map("figma_url")
  developerId    String   @map("developer_id")
  status         String   @default("PENDING") // PENDING, IN_PROGRESS, IMPLEMENTED, VERIFIED
  priority       String   @default("NORMAL") // HIGH, NORMAL, LOW
  specData       String?  @map("spec_data") // JSON string
  notes          String?
  previewImages  String?  @map("preview_images") // JSON array of {url, source, reason}
  createdAt      DateTime @default(now()) @map("created_at")

  figmaProject FigmaProject @relation(fields: [figmaProjectId], references: [id], onDelete: Cascade)
  developer    User         @relation("HandoffDeveloper", fields: [developerId], references: [id])

  @@map("handoffs")
}

model Comment {
  id         String   @id @default(uuid())
  targetType String   @map("target_type") // HANDOFF, REVIEW
  targetId   String   @map("target_id")
  authorId   String   @map("author_id")
  parentId   String?  @map("parent_id")
  content    String
  createdAt  DateTime @default(now()) @map("created_at")

  author   User      @relation(fields: [authorId], references: [id])
  parent   Comment?  @relation("CommentReplies", fields: [parentId], references: [id])
  children Comment[] @relation("CommentReplies")

  @@map("comments")
}
